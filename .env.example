# Copy to `.env` on the server (never commit `.env`).
# See docs/DEPLOYMENT.md for full office deployment steps.

# Required — PostgreSQL connection (local on the app server)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/precastapp"

# Required for production — enables secure session cookies
NODE_ENV=production

# Optional — required to use Settings → Data reset
# SETTINGS_RESET_PASSWORD=your-long-random-secret

# Optional — override default port (default 3000)
# PORT=3000

# Optional — bind address (default 0.0.0.0 in production scripts)
# HOSTNAME=0.0.0.0

# Optional — Office 365 SMTP for Send Quote (requires SMTP AUTH on the mailbox)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=quotes@yourcompany.com
# SMTP_PASSWORD=your-app-password-or-mailbox-password
# SMTP_FROM=quotes@yourcompany.com
# If MFA is enabled on the mailbox, use a Microsoft 365 app password.
# SMTP_FROM must match SMTP_USER or a mailbox the user has Send As rights to.
