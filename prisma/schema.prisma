// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  COMMERCIAL
  RESIDENTIAL
  CONTRACTOR
  OTHER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum JobStatus {
  LEAD
  QUOTING
  SUBMITTED
  AWARDED
  ACTIVE
  ON_HOLD
  COMPLETE
  LOST
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  IN_REVIEW
  SENT
  REVISED
  WON
  LOST
  EXPIRED
  CANCELLED
}

enum QuoteType {
  STOCK_ONLY
  CONFIGURABLE_STRUCTURES
  CUSTOM_STRUCTURES
  MIXED
}

enum QuoteLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum ProductType {
  STOCK
  CONFIGURABLE
  CUSTOM_STRUCTURE
  SERVICE
  MATERIAL
}

enum ProductDocumentType {
  GENERIC_SUBMITTAL
  SHOP_DRAWING
  CUT_SHEET_TEMPLATE
  SPEC_SHEET
  INSTALLATION_INSTRUCTIONS
  OTHER
}

model Product {
  id                   String        @id @default(cuid())
  productCode          String        @unique
  name                 String
  productType          ProductType   @default(STOCK)
  category             String
  description          String?
  unit                 String        @default("EA")
  defaultPrice         Decimal?      @db.Decimal(12, 2)
  cost                 Decimal?      @db.Decimal(12, 2)
  weight               Decimal?      @db.Decimal(12, 2)
  yards                Decimal?      @db.Decimal(12, 4)
  taxable              Boolean       @default(true)
  trackInventory       Boolean       @default(true)
  currentStockQuantity Int           @default(0)
  reorderLevel         Int           @default(0)
  yardLocation         String?
  status               ProductStatus @default(ACTIVE)
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  documents               ProductDocument[]
  jobStructures           JobStructure[]
  castingUsages           JobStructureCasting[] @relation("CastingProduct")
  quoteLineItems          QuoteLineItem[]
  deliveryTicketLineItems DeliveryTicketLineItem[]
  inventoryTransactions   InventoryTransaction[]
  productionLines         DailyProductionLine[]
  priceListItems          PriceListItem[]
  invoiceLineItems        InvoiceLineItem[]
}

model ProductDocument {
  id           String              @id @default(cuid())
  productId    String
  documentType ProductDocumentType
  documentName String
  filePath     String
  fileSize     Int?
  mimeType     String?
  notes        String?
  uploadedAt   DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Customer {
  id                  String         @id @default(cuid())
  name                String
  customerType        CustomerType   @default(CONTRACTOR)
  status              CustomerStatus @default(ACTIVE)
  primaryContactName  String?
  phone               String?
  email               String?
  billingAddress      String?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  contacts        Contact[]
  jobs            Job[]
  quotes          Quote[]
  deliveryTickets DeliveryTicket[]
  invoices        Invoice[]
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  title      String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Job {
  id             String     @id @default(cuid())
  jobNumber      String     @unique
  year           Int
  yearTwoDigit   Int
  sequenceNumber Int
  customerId     String?
  customerName   String
  projectName    String
  projectAddress String?
  city           String?
  state          String?
  zip            String?
  status         JobStatus  @default(LEAD)
  bidDate        DateTime?
  awardedDate    DateTime?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  folderPath     String?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  files           JobFile[]
  quotes          Quote[]
  jobStructures   JobStructure[]
  deliveryTickets DeliveryTicket[]
  invoices        Invoice[]

  @@unique([year, sequenceNumber])
  @@index([customerId])
  @@index([year])
  @@index([yearTwoDigit])
  @@index([status])
}

model JobSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model JobFile {
  id             String   @id @default(cuid())
  jobId          String
  fileName       String
  filePath       String
  folderCategory String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

enum StructureType {
  STOCK_PRODUCT
  CONFIGURABLE_PRODUCT
  CUSTOM_STRUCTURE
}

enum StructureStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  IN_PRODUCTION
  MADE
  SHIPPED
}

enum JobStructureDocumentType {
  CUT_SHEET
  JOB_SPECIFIC_SUBMITTAL
  APPROVED_SUBMITTAL
  PRODUCTION_DRAWING
  FIELD_SKETCH
  OTHER
}

/// Job-specific structure instance derived from a product template or custom design.
model JobStructure {
  id              String          @id @default(cuid())
  jobId           String?
  quoteId         String?
  productId       String?
  structureType   StructureType
  structureNumber String?
  description     String?
  quantity        Decimal?        @db.Decimal(12, 4)
  unit            String?
  weight          Decimal?        @db.Decimal(12, 2)
  yards           Decimal?        @db.Decimal(12, 4)
  status          StructureStatus @default(NOT_SUBMITTED)
  productionDate  DateTime?
  submittedDate   DateTime?
  approvedDate    DateTime?
  madeDate        DateTime?
  shippedDate     DateTime?
  needsCutSheet   Boolean         @default(false)
  needsSubmittal  Boolean         @default(false)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  job                    Job?                     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quote                  Quote?                   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  product                Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)
  quoteLineItems         QuoteLineItem[]
  deliveryTicketLineItems DeliveryTicketLineItem[]
  openings               JobStructureOpening[]
  castings               JobStructureCasting[]
  dimensions             JobStructureDimension?
  manholeDetail          JobStructureManholeDetail?
  documents              JobStructureDocument[]

  @@index([jobId])
  @@index([quoteId])
  @@index([productId])
  @@index([status])
}

model JobStructureOpening {
  id              String   @id @default(cuid())
  jobStructureId  String
  openingNumber   Int?
  wallLocation    String?
  clockPosition   String?
  pipeType        String?
  pipeDiameter    Decimal? @db.Decimal(12, 4)
  connectionType  String?
  invertElevation Decimal? @db.Decimal(12, 4)
  holeDiameter    Decimal? @db.Decimal(12, 4)
  bootType        String?
  gasketType      String?
  sleeveType      String?
  angle           Decimal? @db.Decimal(12, 4)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

model JobStructureCasting {
  id                 String   @id @default(cuid())
  jobStructureId     String
  castingProductId   String?
  castingType        String?
  castingDescription String?
  frameSize          String?
  coverType          String?
  grateType          String?
  hatchSize          String?
  loadRating         String?
  boltDown           Boolean?
  vented             Boolean?
  quantity           Decimal? @db.Decimal(12, 4)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobStructure   JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
  castingProduct Product?     @relation("CastingProduct", fields: [castingProductId], references: [id], onDelete: SetNull)

  @@index([jobStructureId])
  @@index([castingProductId])
}

model JobStructureDimension {
  id                String   @id @default(cuid())
  jobStructureId    String   @unique
  insideLength      Decimal? @db.Decimal(12, 4)
  insideWidth       Decimal? @db.Decimal(12, 4)
  insideHeight      Decimal? @db.Decimal(12, 4)
  outsideLength     Decimal? @db.Decimal(12, 4)
  outsideWidth      Decimal? @db.Decimal(12, 4)
  outsideHeight     Decimal? @db.Decimal(12, 4)
  wallThickness     Decimal? @db.Decimal(12, 4)
  topSlabThickness  Decimal? @db.Decimal(12, 4)
  baseSlabThickness Decimal? @db.Decimal(12, 4)
  haunch            Decimal? @db.Decimal(12, 4)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
}

model JobStructureManholeDetail {
  id                    String   @id @default(cuid())
  jobStructureId        String   @unique
  manholeStandard       String?
  rimElevation          Decimal? @db.Decimal(12, 4)
  lowestInvertElevation Decimal? @db.Decimal(12, 4)
  requiredWallHeight    Decimal? @db.Decimal(12, 4)
  baseSlabThickness     Decimal? @db.Decimal(12, 4)
  topSlabThickness      Decimal? @db.Decimal(12, 4)
  insideDiameter        Decimal? @db.Decimal(12, 4)
  coneOrFlatTop         String?
  frameAndCoverType     String?
  chimneyHeight         Decimal? @db.Decimal(12, 4)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
}

model JobStructureDocument {
  id             String                   @id @default(cuid())
  jobStructureId String
  documentType   JobStructureDocumentType
  documentName   String
  filePath       String
  fileSize       Int?
  mimeType       String?
  uploadedAt     DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  notes          String?

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

/// Customer quote for precast products, configurable structures, custom structures, and services.
/// Quote numbers follow Q-YY-###-R# format (e.g. Q-26-001-R0); generation logic to be added later.
model Quote {
  id                 String      @id @default(cuid())
  quoteNumber        String      @unique
  revisionNumber     Int         @default(0)
  originalQuoteId    String?
  jobId              String?
  customerId         String?
  jobNumber          String?
  customerName       String
  projectName        String
  projectAddress     String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  status             QuoteStatus @default(DRAFT)
  quoteType          QuoteType   @default(MIXED)
  estimator          String?
  quoteDate          DateTime?
  bidDueDate         DateTime?
  expirationDate     DateTime?
  priceListId        String?
  customerPO         String?
  subtotal           Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal     @default(0) @db.Decimal(12, 2)
  deliveryAmount     Decimal     @default(0) @db.Decimal(12, 2)
  taxableAmount      Decimal     @default(0) @db.Decimal(12, 2)
  taxRate            Decimal     @default(0) @db.Decimal(6, 4)
  salesTax           Decimal     @default(0) @db.Decimal(12, 2)
  total              Decimal     @default(0) @db.Decimal(12, 2)
  totalWeight        Decimal     @default(0) @db.Decimal(12, 2)
  totalYards         Decimal     @default(0) @db.Decimal(12, 4)
  internalNotes      String?
  customerNotes      String?
  termsAndConditions String?
  leadTime           String?
  deliveryNotes      String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  job             Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  priceList       PriceList?       @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  lineItems       QuoteLineItem[]
  jobStructures   JobStructure[]
  deliveryTickets DeliveryTicket[]
  invoices        Invoice[]

  @@index([jobId])
  @@index([customerId])
  @@index([priceListId])
  @@index([status])
  @@index([quoteDate])
}

/// Individual line on a quote: stock product, configurable/custom structure, service, or misc item.
model QuoteLineItem {
  id             String        @id @default(cuid())
  quoteId        String
  lineNumber     Int
  lineType       QuoteLineType
  productId      String?
  jobStructureId String?
  itemCode       String
  description    String?
  quantity       Decimal       @default(1) @db.Decimal(12, 4)
  unit           String        @default("EA")
  unitPrice      Decimal       @default(0) @db.Decimal(12, 2)
  weight         Decimal?      @db.Decimal(12, 2)
  yards          Decimal?      @db.Decimal(12, 4)
  taxable        Boolean       @default(true)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  statusNote     String?
  sortOrder      Int           @default(0)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  quote                   Quote                    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product                 Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)
  jobStructure            JobStructure?            @relation(fields: [jobStructureId], references: [id], onDelete: SetNull)
  deliveryTicketLineItems DeliveryTicketLineItem[]
  invoiceLineItems        InvoiceLineItem[]

  @@index([quoteId])
  @@index([productId])
  @@index([jobStructureId])
}

enum DeliveryTicketStatus {
  DRAFT
  SCHEDULED
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum DeliveryTicketType {
  JOB
  WALK_IN
}

enum DeliveryLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
}

enum DeliveryItemStatus {
  NOT_READY
  READY
  LOADING
  LOADED
  DELIVERED
  CANCELLED
}

/// Delivery ticket for scheduling and tracking job deliveries.
/// Ticket numbers follow DT-YY-### format (e.g. DT-26-001); generation logic to be added later.
model DeliveryTicket {
  id                     String               @id @default(cuid())
  ticketNumber           String               @unique
  year                   Int
  yearTwoDigit           Int
  sequenceNumber         Int
  ticketType             DeliveryTicketType   @default(JOB)
  status                 DeliveryTicketStatus @default(DRAFT)
  jobId                  String?
  quoteId                String?
  customerId             String?
  priceListId            String?
  jobNumber              String?
  quoteNumber            String?
  customerName           String
  projectName            String
  deliveryAddress        String?
  siteContactName        String?
  siteContactPhone       String?
  siteContactEmail       String?
  siteInstructions       String?
  deliveryDate           DateTime?
  deliveryTime           String?
  requestedBy            String?
  createdBy              String?
  truck                  String?
  trailer                String?
  driver                 String?
  loadSequence           String?
  specialEquipmentNeeded String?
  craneRequired          Boolean              @default(false)
  forkliftRequired       Boolean              @default(false)
  totalItems             Int?
  totalWeight            Decimal?             @db.Decimal(12, 2)
  driverNotes            String?
  internalNotes          String?
  customerNotes          String?
  loadingNotes           String?
  deliveredAt            DateTime?
  signedBy               String?
  paperTicketPrinted     Boolean              @default(false)
  paperTicketVerified    Boolean              @default(false)
  verifiedAt             DateTime?
  verifiedBy             String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  job       Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quote     Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  customer  Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  priceList PriceList?  @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  invoice   Invoice?
  lineItems DeliveryTicketLineItem[]

  @@unique([year, sequenceNumber])
  @@index([jobId])
  @@index([quoteId])
  @@index([customerId])
  @@index([priceListId])
  @@index([status])
  @@index([deliveryDate])
  @@index([yearTwoDigit])
  @@index([ticketType])
}

/// Individual line on a delivery ticket: stock product, structure, service, or misc item.
model DeliveryTicketLineItem {
  id               String             @id @default(cuid())
  deliveryTicketId String
  lineNumber       Int
  lineType         DeliveryLineType
  productId        String?
  quoteLineItemId  String?
  jobStructureId   String?
  itemCode         String
  description      String?
  quantity         Decimal            @default(1) @db.Decimal(12, 4)
  unit             String             @default("EA")
  weightEach       Decimal?           @db.Decimal(12, 2)
  totalWeight      Decimal?           @db.Decimal(12, 2)
  yardLocation     String?
  status           DeliveryItemStatus @default(NOT_READY)
  notes            String?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  deliveryTicket  DeliveryTicket  @relation(fields: [deliveryTicketId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  quoteLineItem   QuoteLineItem?  @relation(fields: [quoteLineItemId], references: [id], onDelete: SetNull)
  jobStructure    JobStructure?   @relation(fields: [jobStructureId], references: [id], onDelete: SetNull)
  invoiceLineItems InvoiceLineItem[]

  @@index([deliveryTicketId])
  @@index([productId])
  @@index([quoteLineItemId])
  @@index([jobStructureId])
}

/// Per-year sequence counter for delivery ticket numbers (DT-YY-###).
model DeliveryTicketSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum InventoryTransactionType {
  PRODUCTION
  DELIVERY
  ADJUSTMENT
  REVERSAL
}

enum InventoryReferenceType {
  DAILY_PRODUCTION_LINE
  DELIVERY_TICKET_LINE_ITEM
}

/// Append-only ledger for stock inventory changes.
model InventoryTransaction {
  id              String                   @id @default(cuid())
  productId       String
  quantityChange  Decimal                  @db.Decimal(12, 4)
  transactionType InventoryTransactionType
  transactionDate DateTime
  referenceType   InventoryReferenceType?
  referenceId     String?
  notes           String?
  createdBy       String?
  createdAt       DateTime                 @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([transactionDate])
  @@index([referenceType, referenceId])
}

/// Daily batch entry for stock production (yard output).
model DailyProductionEntry {
  id             String   @id @default(cuid())
  productionDate DateTime @db.Date
  batchLabel     String?
  enteredBy      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines DailyProductionLine[]

  @@index([productionDate])
}

/// One product/qty row on a daily production entry.
model DailyProductionLine {
  id               String  @id @default(cuid())
  productionEntryId String
  productId        String
  quantityProduced Decimal @db.Decimal(12, 4)

  productionEntry DailyProductionEntry @relation(fields: [productionEntryId], references: [id], onDelete: Cascade)
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productionEntryId])
  @@index([productId])
}

/// Daily confirmation that printed paper tickets match digital records.
model DeliveryDayReconciliation {
  id                 String   @id @default(cuid())
  reconciliationDate DateTime @unique @db.Date
  confirmedBy        String?
  confirmedAt        DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum InvoiceLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
}

/// Customer invoice — one per delivered delivery ticket.
model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  year            Int
  yearTwoDigit    Int
  sequenceNumber  Int
  deliveryTicketId String       @unique
  jobId           String?
  quoteId         String?
  customerId      String?
  jobNumber       String?
  customerName    String
  projectName     String
  status          InvoiceStatus @default(DRAFT)
  subtotal        Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  deliveryAmount  Decimal       @default(0) @db.Decimal(12, 2)
  taxableAmount   Decimal       @default(0) @db.Decimal(12, 2)
  taxRate         Decimal       @default(0) @db.Decimal(6, 4)
  salesTax        Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @default(0) @db.Decimal(12, 2)
  invoiceDate     DateTime?
  dueDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  deliveryTicket DeliveryTicket @relation(fields: [deliveryTicketId], references: [id], onDelete: Restrict)
  job            Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quote          Quote?         @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lineItems      InvoiceLineItem[]

  @@unique([year, sequenceNumber])
  @@index([jobId])
  @@index([quoteId])
  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
}

model InvoiceLineItem {
  id                       String          @id @default(cuid())
  invoiceId                String
  lineNumber               Int
  lineType                 InvoiceLineType
  quoteLineItemId          String?
  deliveryTicketLineItemId String?
  productId                String?
  itemCode                 String
  description              String?
  quantity                 Decimal         @default(1) @db.Decimal(12, 4)
  unit                     String          @default("EA")
  unitPrice                Decimal         @default(0) @db.Decimal(12, 2)
  taxable                  Boolean         @default(true)
  total                    Decimal         @default(0) @db.Decimal(12, 2)
  sortOrder                Int             @default(0)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  invoice                Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  quoteLineItem          QuoteLineItem?          @relation(fields: [quoteLineItemId], references: [id], onDelete: SetNull)
  deliveryTicketLineItem DeliveryTicketLineItem? @relation(fields: [deliveryTicketLineItemId], references: [id], onDelete: SetNull)
  product                Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([quoteLineItemId])
  @@index([deliveryTicketLineItemId])
  @@index([productId])
}

/// Per-year sequence counter for invoice numbers.
model InvoiceSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Product pricing list for quotes and walk-in delivery tickets.
model PriceList {
  id            String    @id @default(cuid())
  name          String    @unique
  effectiveDate DateTime?
  isDefault     Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items           PriceListItem[]
  quotes          Quote[]
  deliveryTickets DeliveryTicket[]
}

model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  unitPrice   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@index([productId])
}

/// Singleton application configuration (id is always "default").
model AppSettings {
  id        String   @id @default("default")
  // company
  companyName     String
  companyAddress  String
  companyPhone    String
  companyEmail    String
  appTitle        String
  appSubtitle     String
  quoteFooterText String?
  companyLogoPath   String?
  // paths
  jobsRoot            String
  quotePdfFallbackDir String
