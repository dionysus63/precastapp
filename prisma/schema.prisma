// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  COMMERCIAL
  RESIDENTIAL
  CONTRACTOR
  OTHER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum JobStatus {
  LEAD
  QUOTING
  SUBMITTED
  AWARDED
  ACTIVE
  ON_HOLD
  COMPLETE
  LOST
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  IN_REVIEW
  SENT
  REVISED
  WON
  LOST
  EXPIRED
  CANCELLED
}

enum QuoteType {
  STOCK_ONLY
  CONFIGURABLE_STRUCTURES
  CUSTOM_STRUCTURES
  MIXED
}

enum QuoteLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum ProductType {
  STOCK
  CONFIGURABLE
  CUSTOM_STRUCTURE
  SERVICE
  MATERIAL
}

enum ProductDocumentType {
  GENERIC_SUBMITTAL
  SHOP_DRAWING
  CUT_SHEET_TEMPLATE
  SPEC_SHEET
  INSTALLATION_INSTRUCTIONS
  OTHER
}

model Product {
  id                   String        @id @default(cuid())
  productCode          String        @unique
  name                 String
  productType          ProductType   @default(STOCK)
  category             String
  description          String?
  unit                 String        @default("EA")
  defaultPrice         Decimal?      @db.Decimal(12, 2)
  cost                 Decimal?      @db.Decimal(12, 2)
  weight               Decimal?      @db.Decimal(12, 2)
  yards                Decimal?      @db.Decimal(12, 4)
  taxable              Boolean       @default(true)
  trackInventory       Boolean       @default(true)
  currentStockQuantity Int           @default(0)
  reorderLevel         Int           @default(0)
  yardLocation         String?
  status               ProductStatus @default(ACTIVE)
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  documents      ProductDocument[]
  jobStructures  JobStructure[]
  castingUsages  JobStructureCasting[] @relation("CastingProduct")
  quoteLineItems QuoteLineItem[]
}

model ProductDocument {
  id           String              @id @default(cuid())
  productId    String
  documentType ProductDocumentType
  documentName String
  filePath     String
  fileSize     Int?
  mimeType     String?
  notes        String?
  uploadedAt   DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Customer {
  id                  String         @id @default(cuid())
  name                String
  customerType        CustomerType   @default(CONTRACTOR)
  status              CustomerStatus @default(ACTIVE)
  primaryContactName  String?
  phone               String?
  email               String?
  billingAddress      String?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  contacts Contact[]
  jobs     Job[]
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  title      String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Job {
  id             String     @id @default(cuid())
  jobNumber      String     @unique
  year           Int
  yearTwoDigit   Int
  sequenceNumber Int
  customerId     String?
  customerName   String
  projectName    String
  projectAddress String?
  city           String?
  state          String?
  zip            String?
  status         JobStatus  @default(LEAD)
  bidDate        DateTime?
  awardedDate    DateTime?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  folderPath     String?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  files    JobFile[]

  @@unique([year, sequenceNumber])
  @@index([customerId])
  @@index([year])
  @@index([yearTwoDigit])
  @@index([status])
}

model JobSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model JobFile {
  id             String   @id @default(cuid())
  jobId          String
  fileName       String
  filePath       String
  folderCategory String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

enum StructureType {
  STOCK_PRODUCT
  CONFIGURABLE_PRODUCT
  CUSTOM_STRUCTURE
}

enum StructureStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  IN_PRODUCTION
  MADE
  SHIPPED
}

enum JobStructureDocumentType {
  CUT_SHEET
  JOB_SPECIFIC_SUBMITTAL
  APPROVED_SUBMITTAL
  PRODUCTION_DRAWING
  FIELD_SKETCH
  OTHER
}

/// Job-specific structure instance derived from a product template or custom design.
model JobStructure {
  id              String          @id @default(cuid())
  /// TODO: replace with Job relation when job structures are wired to the jobs module
  jobId           String?
  /// TODO: replace with Quote relation when a Quote model exists
  quoteId         String?
  productId       String?
  structureType   StructureType
  structureNumber String?
  description     String?
  quantity        Decimal?        @db.Decimal(12, 4)
  unit            String?
  weight          Decimal?        @db.Decimal(12, 2)
  yards           Decimal?        @db.Decimal(12, 4)
  status          StructureStatus @default(NOT_SUBMITTED)
  productionDate  DateTime?
  submittedDate   DateTime?
  approvedDate    DateTime?
  madeDate        DateTime?
  shippedDate     DateTime?
  needsCutSheet   Boolean         @default(false)
  needsSubmittal  Boolean         @default(false)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  product       Product?                   @relation(fields: [productId], references: [id], onDelete: SetNull)
  openings      JobStructureOpening[]
  castings      JobStructureCasting[]
  dimensions    JobStructureDimension?
  manholeDetail JobStructureManholeDetail?
  documents     JobStructureDocument[]

  @@index([jobId])
  @@index([quoteId])
  @@index([productId])
}

model JobStructureOpening {
  id              String   @id @default(cuid())
  jobStructureId  String
  openingNumber   Int?
  wallLocation    String?
  clockPosition   String?
  pipeType        String?
  pipeDiameter    Decimal? @db.Decimal(12, 4)
  connectionType  String?
  invertElevation Decimal? @db.Decimal(12, 4)
  holeDiameter    Decimal? @db.Decimal(12, 4)
  bootType        String?
  gasketType      String?
  sleeveType      String?
  angle           Decimal? @db.Decimal(12, 4)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

model JobStructureCasting {
  id                 String   @id @default(cuid())
  jobStructureId     String
  castingProductId   String?
  castingType        String?
  castingDescription String?
  frameSize          String?
  coverType          String?
  grateType          String?
  hatchSize          String?
  loadRating         String?
  boltDown           Boolean?
  vented             Boolean?
  quantity           Decimal? @db.Decimal(12, 4)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobStructure   JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
  castingProduct Product?     @relation("CastingProduct", fields: [castingProductId], references: [id], onDelete: SetNull)

  @@index([jobStructureId])
  @@index([castingProductId])
}

model JobStructureDimension {
  id                String   @id @default(cuid())
  jobStructureId    String   @unique
  insideLength      Decimal? @db.Decimal(12, 4)
  insideWidth       Decimal? @db.Decimal(12, 4)
  insideHeight      Decimal? @db.Decimal(12, 4)
  outsideLength     Decimal? @db.Decimal(12, 4)
  outsideWidth      Decimal? @db.Decimal(12, 4)
  outsideHeight     Decimal? @db.Decimal(12, 4)
  wallThickness     Decimal? @db.Decimal(12, 4)
  topSlabThickness  Decimal? @db.Decimal(12, 4)
  baseSlabThickness Decimal? @db.Decimal(12, 4)
  haunch            Decimal? @db.Decimal(12, 4)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
}

model JobStructureManholeDetail {
  id                    String   @id @default(cuid())
  jobStructureId        String   @unique
  manholeStandard       String?
  rimElevation          Decimal? @db.Decimal(12, 4)
  lowestInvertElevation Decimal? @db.Decimal(12, 4)
  requiredWallHeight    Decimal? @db.Decimal(12, 4)
  baseSlabThickness     Decimal? @db.Decimal(12, 4)
  topSlabThickness      Decimal? @db.Decimal(12, 4)
  insideDiameter        Decimal? @db.Decimal(12, 4)
  coneOrFlatTop         String?
  frameAndCoverType     String?
  chimneyHeight         Decimal? @db.Decimal(12, 4)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
}

model JobStructureDocument {
  id             String                   @id @default(cuid())
  jobStructureId String
  documentType   JobStructureDocumentType
  documentName   String
  filePath       String
  fileSize       Int?
  mimeType       String?
  uploadedAt     DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  notes          String?

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

/// Customer quote for precast products, configurable structures, custom structures, and services.
/// Quote numbers follow Q-YY-###-R# format (e.g. Q-26-001-R0); generation logic to be added later.
model Quote {
  id                 String      @id @default(cuid())
  quoteNumber        String      @unique
  revisionNumber     Int         @default(0)
  /// TODO: replace with Quote self-relation when revision chains are wired up
  originalQuoteId    String?
  /// TODO: replace with Job relation when quotes are wired to the jobs module
  jobId              String?
  /// TODO: replace with Customer relation when quotes are wired to the customers module
  customerId         String?
  jobNumber          String?
  customerName       String
  projectName        String
  projectAddress     String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  status             QuoteStatus @default(DRAFT)
  quoteType          QuoteType   @default(MIXED)
  estimator          String?
  quoteDate          DateTime?
  bidDueDate         DateTime?
  expirationDate     DateTime?
  /// TODO: replace with PriceList relation when a PriceList model exists
  priceListId        String?
  customerPO         String?
  subtotal           Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal     @default(0) @db.Decimal(12, 2)
  deliveryAmount     Decimal     @default(0) @db.Decimal(12, 2)
  taxableAmount      Decimal     @default(0) @db.Decimal(12, 2)
  taxRate            Decimal     @default(0) @db.Decimal(6, 4)
  salesTax           Decimal     @default(0) @db.Decimal(12, 2)
  total              Decimal     @default(0) @db.Decimal(12, 2)
  totalWeight        Decimal     @default(0) @db.Decimal(12, 2)
  totalYards         Decimal     @default(0) @db.Decimal(12, 4)
  internalNotes      String?
  customerNotes      String?
  termsAndConditions String?
  leadTime           String?
  deliveryNotes      String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  lineItems QuoteLineItem[]

  @@index([jobId])
  @@index([customerId])
  @@index([status])
  @@index([quoteDate])
}

/// Individual line on a quote: stock product, configurable/custom structure, service, or misc item.
model QuoteLineItem {
  id             String        @id @default(cuid())
  quoteId        String
  lineNumber     Int
  lineType       QuoteLineType
  productId      String?
  /// TODO: replace with JobStructure relation when quote line items are wired to job structures
  jobStructureId String?
  itemCode       String
  description    String?
  quantity       Decimal       @default(1) @db.Decimal(12, 4)
  unit           String        @default("EA")
  unitPrice      Decimal       @default(0) @db.Decimal(12, 2)
  weight         Decimal?      @db.Decimal(12, 2)
  yards          Decimal?      @db.Decimal(12, 4)
  taxable        Boolean       @default(true)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  statusNote     String?
  sortOrder      Int           @default(0)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
  @@index([jobStructureId])
}
