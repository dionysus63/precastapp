// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  COMMERCIAL
  RESIDENTIAL
  CONTRACTOR
  OTHER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum JobStatus {
  LEAD
  QUOTED
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model Product {
  id                   String        @id @default(cuid())
  productCode          String        @unique
  productName          String
  category             String
  subcategory          String?
  unit                 String        @default("EA")
  defaultPrice         Decimal?      @db.Decimal(12, 2)
  weight               Decimal?      @db.Decimal(12, 2)
  yards                Decimal?      @db.Decimal(12, 4)
  trackInventory       Boolean       @default(true)
  currentStockQuantity Int           @default(0)
  reorderLevel         Int           @default(0)
  status               ProductStatus @default(ACTIVE)
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Customer {
  id                  String         @id @default(cuid())
  name                String
  customerType        CustomerType   @default(CONTRACTOR)
  status              CustomerStatus @default(ACTIVE)
  primaryContactName  String?
  phone               String?
  email               String?
  billingAddress      String?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  contacts Contact[]
  jobs     Job[]
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  title      String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Job {
  id             String    @id @default(cuid())
  jobNumber      String    @unique
  year           Int
  sequenceNumber Int
  customerId     String
  projectName    String
  projectAddress String?
  status         JobStatus @default(LEAD)
  folderPath     String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  files    JobFile[]

  @@index([customerId])
  @@index([year])
}

model JobSequence {
  year       Int @id
  lastNumber Int @default(0)
}

model JobFile {
  id             String   @id @default(cuid())
  jobId          String
  fileName       String
  filePath       String
  folderCategory String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
