// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum JobStatus {
  LEAD
  QUOTING
  SUBMITTED
  AWARDED
  ACTIVE
  ON_HOLD
  COMPLETE
  LOST
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  IN_REVIEW
  SENT
  REVISED
  WON
  LOST
  LOST_BC
  EXPIRED
  CANCELLED
}

enum QuoteType {
  STOCK_ONLY
  CONFIGURABLE_STRUCTURES
  CUSTOM_STRUCTURES
  MIXED
}

enum QuoteLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
  CATEGORY
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum ProductType {
  STOCK
  CONFIGURABLE
  CUSTOM_STRUCTURE
  SERVICE
  MATERIAL
}

enum ProductDocumentType {
  GENERIC_SUBMITTAL
  SHOP_DRAWING
  CUT_SHEET_TEMPLATE
  SPEC_SHEET
  INSTALLATION_INSTRUCTIONS
  OTHER
}

enum DrainRingStyle {
  DRAIN
  SANITARY
  SOLID
}

enum CastingSupplierOrigin {
  DOMESTIC
  IMPORTED
}

enum CastingSupplierStatus {
  ACTIVE
  INACTIVE
}

enum CastingRole {
  ASSEMBLY
  COMPONENT
}

enum CastingPieceRole {
  FRAME
  COVER_GRATE
  HOOD
  THROAT
}

enum ProductKind {
  STANDARD
  DRAIN_RING
  CASTING_ASSEMBLY
  CASTING_COMPONENT
  PIPE
}

model CastingSupplier {
  id        String                @id @default(cuid())
  name      String                @unique
  origin    CastingSupplierOrigin
  sortOrder Int                   @default(0)
  status    CastingSupplierStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  products         Product[]
  purchaseReceipts PurchaseReceiptEntry[]

  @@index([status])
  @@index([sortOrder])
}

model Product {
  id                   String        @id @default(cuid())
  productCode          String        @unique
  name                 String
  productType          ProductType   @default(STOCK)
  category             String
  description          String?
  unit                 String        @default("EA")
  defaultPrice         Decimal?      @db.Decimal(12, 2)
  cost                 Decimal?      @db.Decimal(12, 2)
  weight               Decimal?      @db.Decimal(12, 2)
  yards                Decimal?      @db.Decimal(12, 4)
  taxable              Boolean       @default(true)
  trackInventory       Boolean       @default(true)
  currentStockQuantity Int           @default(0)
  reorderLevel         Int           @default(0)
  yardLocation         String?
  status               ProductStatus @default(ACTIVE)
  notes                String?
  productKind               ProductKind      @default(STANDARD)
  isDrainRing          Boolean         @default(false)
  heightFeet           Decimal?        @db.Decimal(6, 2)
  ringDiameterFeet     Decimal?        @db.Decimal(6, 2)
  drainRingStyle       DrainRingStyle  @default(DRAIN)
  isCasting                 Boolean          @default(false)
  castingClearOpeningInches Decimal?         @db.Decimal(6, 2)
  castingRole               CastingRole?
  castingPieceRole          CastingPieceRole?
  castingSupplierId         String?
  pipeDiameterInches        Decimal?         @db.Decimal(6, 2)
  pipeLengthFeet            Decimal?         @db.Decimal(6, 2)
  pipeClass                 String?
  pipeJointType             String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime      @updatedAt

  documents               ProductDocument[]
  jobStructures           JobStructure[]
  castingUsages           JobStructureCasting[] @relation("CastingProduct")
  quoteLineItems          QuoteLineItem[]
  deliveryTicketLineItems DeliveryTicketLineItem[]
  inventoryTransactions   InventoryTransaction[]
  productionLines         DailyProductionLine[]
  purchaseReceiptLines    PurchaseReceiptLine[]
  priceListItems          PriceListItem[]
  invoiceLineItems        InvoiceLineItem[]
  castingSupplier         CastingSupplier?              @relation(fields: [castingSupplierId], references: [id], onDelete: SetNull)
  castingAssemblyComponents ProductCastingComponent[]   @relation("CastingAssembly")
  castingComponentOf        ProductCastingComponent[]   @relation("CastingComponent")
  structureTemplates        StructureTemplate[]         @relation("TemplateCasting")

  @@index([productKind])
  @@index([isDrainRing, ringDiameterFeet, drainRingStyle])
  @@index([isCasting])
  @@index([castingRole])
  @@index([castingSupplierId])
  @@index([productKind, pipeDiameterInches])
}

/// BOM link: full casting assembly → frame/cover/grate component SKUs.
model ProductCastingComponent {
  id          String           @id @default(cuid())
  assemblyId  String
  componentId String
  pieceRole   CastingPieceRole
  quantity    Int              @default(1)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  assembly  Product @relation("CastingAssembly", fields: [assemblyId], references: [id], onDelete: Cascade)
  component Product @relation("CastingComponent", fields: [componentId], references: [id], onDelete: Restrict)

  @@unique([assemblyId, pieceRole])
  @@unique([assemblyId, componentId])
  @@index([assemblyId])
  @@index([componentId])
}

model ProductDocument {
  id           String              @id @default(cuid())
  productId    String
  documentType ProductDocumentType
  documentName String
  filePath     String
  fileSize     Int?
  mimeType     String?
  notes        String?
  uploadedAt   DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Customer {
  id                 String         @id @default(cuid())
  name               String
  status             CustomerStatus @default(ACTIVE)
  primaryContactName String?
  phone              String?
  email              String?
  address            String?
  town               String?
  state              String?
  zip                String?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  contacts        Contact[]
  jobs            Job[]
  jobBidders      JobBidder[]
  quotes          Quote[]
  deliveryTickets DeliveryTicket[]
  invoices        Invoice[]
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  title      String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotes   Quote[]

  @@index([customerId])
}

model Job {
  id             String     @id @default(cuid())
  jobNumber      String     @unique
  year           Int
  yearTwoDigit   Int
  sequenceNumber Int
  customerId     String?
  customerName   String
  projectName    String
  projectAddress String?
  city           String?
  state          String?
  zip            String?
  status         JobStatus  @default(LEAD)
  bidDate        DateTime?
  awardedDate    DateTime?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  folderPath     String?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  files           JobFile[]
  bidders         JobBidder[]
  quotes          Quote[]
  jobStructures   JobStructure[]
  deliveryTickets DeliveryTicket[]
  invoices        Invoice[]
  favorites       JobFavorite[]

  @@unique([year, sequenceNumber])
  @@index([customerId])
  @@index([year])
  @@index([yearTwoDigit])
  @@index([status])
}

/// Contractor invited to bid on a job (bid list entry).
model JobBidder {
  id         String   @id @default(cuid())
  jobId      String
  customerId String
  sortOrder  Int      @default(0)
  isWinner   Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotes   Quote[]

  @@unique([jobId, customerId])
  @@index([jobId])
  @@index([customerId])
}

model JobSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model JobFile {
  id             String   @id @default(cuid())
  jobId          String
  fileName       String
  filePath       String
  folderCategory String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, filePath])
  @@index([jobId])
}

enum StructureShape {
  CIRCULAR
  RECTANGULAR
}

enum SectionRole {
  BASE
  RISER
}

enum StructureTemplateStatus {
  ACTIVE
  INACTIVE
}

enum PipeConnectionType {
  KOR_N_SEAL
  CAST_IN
  GROUTED
  OTHER
}

enum SumpMode {
  DEFAULT
  FIXED
}

/// Reusable structure template configured in the Structures tab.
/// Drives the Drill Sheet Workbook calculations.
model StructureTemplate {
  id                          String                  @id @default(cuid())
  name                        String                  @unique
  agencyStandard              String?
  shape                       StructureShape          @default(CIRCULAR)
  wallThicknessInches         Decimal                 @default(8) @db.Decimal(6, 2)
  baseSlabThicknessInches     Decimal                 @default(8) @db.Decimal(6, 2)
  topSlabThicknessInches      Decimal                 @default(16) @db.Decimal(6, 2)
  castingProductId            String?
  minimumBrickInches          Decimal                 @default(4) @db.Decimal(6, 2)
  connectionType              PipeConnectionType      @default(KOR_N_SEAL)
  sumpMode                    SumpMode                @default(DEFAULT)
  sumpFixedInches             Decimal?                @db.Decimal(6, 2)
  openingToJointMinTopInches    Decimal               @default(4) @db.Decimal(6, 2)
  openingToJointMinBottomInches Decimal               @default(4) @db.Decimal(6, 2)
  status                      StructureTemplateStatus @default(ACTIVE)
  notes                       String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt

  castingProduct Product? @relation("TemplateCasting", fields: [castingProductId], references: [id], onDelete: SetNull)
  diameters      StructureTemplateDiameter[]
  templatePdfs   StructureTemplatePdf[]
  jobStructures  JobStructure[]

  @@index([shape])
  @@index([status])
  @@index([castingProductId])
}

/// Fillable drill sheet PDF for a template variant (hasRiser x hasKey matrix).
model StructureTemplatePdf {
  id           String   @id @default(cuid())
  templateId   String
  hasRiser     Boolean
  hasKey       Boolean
  filePath     String
  originalName String
  fileSize     Int?
  uploadedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  template StructureTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, hasRiser, hasKey])
  @@index([templateId])
}

/// One offered inside diameter for a structure template.
model StructureTemplateDiameter {
  id                 String   @id @default(cuid())
  templateId         String
  insideDiameterFeet Decimal  @db.Decimal(6, 2)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  template StructureTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, insideDiameterFeet])
  @@index([templateId])
}

/// Global pipe opening size catalog: material + size + type → hole diameter, boot, price.
model PipeOpeningSize {
  id                 String   @id @default(cuid())
  pipeMaterial       String
  pipeSizeInches     Decimal  @db.Decimal(6, 2)
  pipeType           String
  holeDiameterInches Decimal  @db.Decimal(6, 2)
  bootModel          String?
  pricePerBoot       Decimal? @db.Decimal(12, 2)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([pipeMaterial, pipeSizeInches, pipeType])
  @@index([pipeMaterial])
  @@index([pipeSizeInches])
}

/// Global per-diameter mold limits and pricing (Settings).
model StructureDiameterConfig {
  id                 String   @id @default(cuid())
  insideDiameterFeet Decimal  @unique @db.Decimal(6, 2)
  maxBaseHeightFeet  Decimal  @db.Decimal(6, 2)
  maxRiserHeightFeet Decimal  @db.Decimal(6, 2)
  keyHeightFeet      Decimal  @db.Decimal(6, 4)
  wallPricePerFoot   Decimal  @default(0) @db.Decimal(12, 2)
  basePrice          Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum StructureType {
  STOCK_PRODUCT
  CONFIGURABLE_PRODUCT
  CUSTOM_STRUCTURE
}

enum StructureStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  IN_PRODUCTION
  MADE
  SHIPPED
}

enum JobStructureDocumentType {
  CUT_SHEET
  JOB_SPECIFIC_SUBMITTAL
  APPROVED_SUBMITTAL
  PRODUCTION_DRAWING
  FIELD_SKETCH
  OTHER
}

/// Job-specific structure instance derived from a product template or custom design.
model JobStructure {
  id                  String          @id @default(cuid())
  jobId               String?
  quoteId             String?
  productId           String?
  structureTemplateId String?
  structureType   StructureType
  structureNumber String?
  description     String?
  quantity        Decimal?        @db.Decimal(12, 4)
  unit            String?
  weight          Decimal?        @db.Decimal(12, 2)
  yards           Decimal?        @db.Decimal(12, 4)
  status          StructureStatus @default(NOT_SUBMITTED)
  productionDate  DateTime?
  submittedDate   DateTime?
  approvedDate    DateTime?
  madeDate        DateTime?
  shippedDate     DateTime?
  needsCutSheet   Boolean         @default(false)
  needsSubmittal  Boolean         @default(false)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  job                    Job?                     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quote                  Quote?                   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  product                Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)
  structureTemplate      StructureTemplate?       @relation(fields: [structureTemplateId], references: [id], onDelete: SetNull)
  quoteLineItems         QuoteLineItem[]
  deliveryTicketLineItems DeliveryTicketLineItem[]
  openings               JobStructureOpening[]
  castings               JobStructureCasting[]
  sections               JobStructureSection[]
  dimensions             JobStructureDimension?
  calc                   JobStructureCalc?
  documents              JobStructureDocument[]

  @@index([jobId])
  @@index([quoteId])
  @@index([productId])
  @@index([structureTemplateId])
  @@index([status])
}

/// Base/riser breakdown of a configured drill-sheet structure's precast wall.
model JobStructureSection {
  id             String      @id @default(cuid())
  jobStructureId String
  role           SectionRole
  heightFeet     Decimal     @db.Decimal(6, 4)
  label          String?
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

model JobStructureOpening {
  id                           String              @id @default(cuid())
  jobStructureId               String
  openingNumber                Int?
  label                        String?
  invertElevation              Decimal?            @db.Decimal(12, 4)
  pipeSizeInches               Decimal?            @db.Decimal(6, 2)
  pipeMaterial                 String?
  pipeType                     String?
  angle                        Decimal?            @db.Decimal(12, 4)
  connectionType               PipeConnectionType?
  holeDiameterInches           Decimal?            @db.Decimal(6, 2)
  bootModel                    String?
  topOfPipeFeet                Decimal?            @db.Decimal(12, 4)
  bottomOfOpeningFeet          Decimal?            @db.Decimal(12, 4)
  topOfOpeningFeet             Decimal?            @db.Decimal(12, 4)
  baseTopToOpeningBottomInches Int?
  pricePerBoot                 Decimal?            @db.Decimal(12, 2)
  notes                        String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

model JobStructureCasting {
  id                 String   @id @default(cuid())
  jobStructureId     String
  castingProductId   String?
  castingType        String?
  castingDescription String?
  frameSize          String?
  coverType          String?
  grateType          String?
  hatchSize          String?
  loadRating         String?
  boltDown           Boolean?
  vented             Boolean?
  quantity           Decimal? @db.Decimal(12, 4)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobStructure   JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
  castingProduct Product?     @relation("CastingProduct", fields: [castingProductId], references: [id], onDelete: SetNull)

  @@index([jobStructureId])
  @@index([castingProductId])
}

model JobStructureDimension {
  id                String   @id @default(cuid())
  jobStructureId    String   @unique
  insideLength      Decimal? @db.Decimal(12, 4)
  insideWidth       Decimal? @db.Decimal(12, 4)
  insideHeight      Decimal? @db.Decimal(12, 4)
  outsideLength     Decimal? @db.Decimal(12, 4)
  outsideWidth      Decimal? @db.Decimal(12, 4)
  outsideHeight     Decimal? @db.Decimal(12, 4)
  wallThickness     Decimal? @db.Decimal(12, 4)
  topSlabThickness  Decimal? @db.Decimal(12, 4)
  baseSlabThickness Decimal? @db.Decimal(12, 4)
  haunch            Decimal? @db.Decimal(12, 4)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
}

model JobStructureCalc {
  id                    String    @id @default(cuid())
  jobStructureId        String    @unique
  contractorName        String?
  projectName           String?
  sheetDate             DateTime?
  hasSteps              Boolean   @default(false)
  inspection            String?
  approvedBy            String?
  useBase               String?
  useRiser              String?
  brickAdjustment       String?
  rimElevation          Decimal?  @db.Decimal(12, 4)
  lowestInvertFeet      Decimal?  @db.Decimal(12, 4)
  sumpFeet              Decimal?  @db.Decimal(12, 4)
  castingHeightFeet     Decimal?  @db.Decimal(12, 4)
  topSlabThicknessFeet  Decimal?  @db.Decimal(12, 4)
  wallHeightFeet        Decimal?  @db.Decimal(12, 4)
  brickFeet               Decimal?  @db.Decimal(12, 4)
  hasKey                  Boolean   @default(true)
  totalHeightFeet         Decimal?  @db.Decimal(12, 4)
  insideDiameterFeet      Decimal?  @db.Decimal(12, 4)
  baseSlabThicknessFeet   Decimal?  @db.Decimal(12, 4)
  wallPrice               Decimal?  @db.Decimal(12, 2)
  bootsPrice              Decimal?  @db.Decimal(12, 2)
  totalPrice              Decimal?  @db.Decimal(12, 2)
  errorMessage            String?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)
}

model JobStructureDocument {
  id             String                   @id @default(cuid())
  jobStructureId String
  documentType   JobStructureDocumentType
  documentName   String
  filePath       String
  fileSize       Int?
  mimeType       String?
  uploadedAt     DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  notes          String?

  jobStructure JobStructure @relation(fields: [jobStructureId], references: [id], onDelete: Cascade)

  @@index([jobStructureId])
}

/// Customer quote for precast products, configurable structures, custom structures, and services.
/// Quote numbers follow Q-{job}-{scope?}-{contractor?}-R{n} (e.g. Q-26-001-SITE-BAY-R1); R0 is implicit.
model Quote {
  id                 String      @id @default(cuid())
  quoteNumber        String      @unique
  revisionNumber     Int         @default(0)
  originalQuoteId    String?
  masterQuoteId      String?
  jobId              String?
  jobBidderId        String?
  customerId         String?
  jobNumber          String?
  customerName       String
  projectName        String
  scopeLabel         String?
  projectAddress     String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  contactId          String?
  contactTitle       String?
  status             QuoteStatus @default(DRAFT)
  quoteType          QuoteType   @default(MIXED)
  estimator          String?
  createdById        String?
  quoteDate          DateTime?
  bidDueDate         DateTime?
  expirationDate     DateTime?
  priceListId        String?
  customerPO         String?
  subtotal           Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal     @default(0) @db.Decimal(12, 2)
  deliveryAmount     Decimal     @default(0) @db.Decimal(12, 2)
  taxableAmount      Decimal     @default(0) @db.Decimal(12, 2)
  taxRate            Decimal     @default(0) @db.Decimal(6, 4)
  salesTax           Decimal     @default(0) @db.Decimal(12, 2)
  total              Decimal     @default(0) @db.Decimal(12, 2)
  totalWeight        Decimal     @default(0) @db.Decimal(12, 2)
  totalYards         Decimal     @default(0) @db.Decimal(12, 4)
  internalNotes      String?
  customerNotes      String?
  termsAndConditions String?
  leadTime           String?
  deliveryNotes      String?
  sentAt             DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  job             Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  jobBidder       JobBidder?       @relation(fields: [jobBidderId], references: [id], onDelete: SetNull)
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contact         Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  priceList       PriceList?       @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  originalQuote   Quote?           @relation("QuoteRevisions", fields: [originalQuoteId], references: [id], onDelete: SetNull)
  revisions       Quote[]          @relation("QuoteRevisions")
  masterQuote     Quote?           @relation("QuoteBidderGroup", fields: [masterQuoteId], references: [id], onDelete: SetNull)
  bidderQuotes    Quote[]          @relation("QuoteBidderGroup")
  lineItems       QuoteLineItem[]
  jobStructures   JobStructure[]
  deliveryTickets DeliveryTicket[]
  invoices        Invoice[]

  @@index([jobId])
  @@index([jobBidderId])
  @@index([customerId])
  @@index([contactId])
  @@index([priceListId])
  @@index([originalQuoteId])
  @@index([masterQuoteId])
  @@index([status])
  @@index([quoteDate])
  @@index([createdById])
}

/// Individual line on a quote: stock product, configurable/custom structure, service, or misc item.
model QuoteLineItem {
  id                 String        @id @default(cuid())
  quoteId            String
  previousLineItemId String?
  lineNumber         Int
  lineType           QuoteLineType
  productId          String?
  jobStructureId     String?
  itemCode           String
  description    String?
  quantity       Decimal       @default(1) @db.Decimal(12, 4)
  unit           String        @default("EA")
  unitPrice      Decimal       @default(0) @db.Decimal(12, 2)
  weight         Decimal?      @db.Decimal(12, 2)
  yards          Decimal?      @db.Decimal(12, 4)
  taxable        Boolean       @default(true)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  statusNote     String?
  sortOrder      Int           @default(0)
  notes          String?
  isDrainRing      Boolean        @default(false)
  ringDiameterFeet Decimal?       @db.Decimal(6, 2)
  poolHeightFeet   Decimal?       @db.Decimal(6, 2)
  drainRingStyle        DrainRingStyle @default(DRAIN)
  structureConfigJson   Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  quote                   Quote                    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  previousLineItem        QuoteLineItem?           @relation("QuoteLineLineage", fields: [previousLineItemId], references: [id], onDelete: SetNull)
  supersededBy            QuoteLineItem[]          @relation("QuoteLineLineage")
  product                 Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)
  jobStructure            JobStructure?            @relation(fields: [jobStructureId], references: [id], onDelete: SetNull)
  deliveryTicketLineItems DeliveryTicketLineItem[]
  invoiceLineItems        InvoiceLineItem[]

  @@index([quoteId])
  @@index([previousLineItemId])
  @@index([productId])
  @@index([jobStructureId])
}

enum DeliveryTicketStatus {
  DRAFT
  SCHEDULED
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum DeliveryTicketType {
  JOB
  WALK_IN
}

enum DeliveryLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
}

enum DeliveryItemStatus {
  NOT_READY
  READY
  LOADING
  LOADED
  DELIVERED
  CANCELLED
}

/// Whether the company delivers the load or the customer picks it up.
enum FulfillmentMethod {
  DELIVERY
  PICKUP
}

/// How a pickup / walk-in customer is paying for the load.
enum TicketPaymentMethod {
  PAY_NOW
  ON_ACCOUNT
}

/// Delivery ticket for scheduling and tracking job deliveries.
/// Ticket numbers follow DT##### format (e.g. DT10001); global sequence starting at 10001.
model DeliveryTicket {
  id                     String               @id @default(cuid())
  ticketNumber           String               @unique
  year                   Int
  yearTwoDigit           Int
  sequenceNumber         Int
  ticketType             DeliveryTicketType   @default(JOB)
  fulfillmentMethod      FulfillmentMethod    @default(DELIVERY)
  status                 DeliveryTicketStatus @default(DRAFT)
  jobId                  String?
  quoteId                String?
  customerId             String?
  priceListId            String?
  jobNumber              String?
  quoteNumber            String?
  customerName           String
  projectName            String
  deliveryAddress        String?
  siteContactName        String?
  siteContactPhone       String?
  siteContactEmail       String?
  siteInstructions       String?
  deliveryDate           DateTime?
  deliveryTime           String?
  requestedBy            String?
  createdBy              String?
  truck                  String?
  trailer                String?
  driver                 String?
  loadSequence           String?
  specialEquipmentNeeded String?
  craneRequired          Boolean              @default(false)
  forkliftRequired       Boolean              @default(false)
  totalItems             Int?
  totalWeight            Decimal?             @db.Decimal(12, 2)
  paymentMethod          TicketPaymentMethod?
  paymentReceived        Boolean              @default(false)
  pickedUpBy             String?
  driverNotes            String?
  internalNotes          String?
  customerNotes          String?
  loadingNotes           String?
  deliveredAt            DateTime?
  signedBy               String?
  paperTicketPrinted     Boolean              @default(false)
  paperTicketVerified    Boolean              @default(false)
  verifiedAt             DateTime?
  verifiedBy             String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  job       Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quote     Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  customer  Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  priceList PriceList?  @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  invoice   Invoice?
  lineItems DeliveryTicketLineItem[]

  @@unique([year, sequenceNumber])
  @@index([jobId])
  @@index([quoteId])
  @@index([customerId])
  @@index([priceListId])
  @@index([status])
  @@index([deliveryDate])
  @@index([yearTwoDigit])
  @@index([ticketType])
  @@index([fulfillmentMethod])
}

/// Individual line on a delivery ticket: stock product, structure, service, or misc item.
model DeliveryTicketLineItem {
  id               String             @id @default(cuid())
  deliveryTicketId String
  lineNumber       Int
  lineType         DeliveryLineType
  productId        String?
  quoteLineItemId  String?
  jobStructureId   String?
  itemCode         String
  description      String?
  quantity         Decimal            @default(1) @db.Decimal(12, 4)
  unit             String             @default("EA")
  weightEach       Decimal?           @db.Decimal(12, 2)
  totalWeight      Decimal?           @db.Decimal(12, 2)
  yardLocation     String?
  status           DeliveryItemStatus @default(NOT_READY)
  notes            String?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  deliveryTicket  DeliveryTicket  @relation(fields: [deliveryTicketId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  quoteLineItem   QuoteLineItem?  @relation(fields: [quoteLineItemId], references: [id], onDelete: SetNull)
  jobStructure    JobStructure?   @relation(fields: [jobStructureId], references: [id], onDelete: SetNull)
  invoiceLineItems InvoiceLineItem[]

  @@index([deliveryTicketId])
  @@index([productId])
  @@index([quoteLineItemId])
  @@index([jobStructureId])
}

/// Global sequence counter for delivery ticket numbers (year=0 row; DT10001+).
model DeliveryTicketSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum InventoryTransactionType {
  PRODUCTION
  DELIVERY
  ADJUSTMENT
  REVERSAL
  PURCHASE_RECEIPT
}

enum InventoryReferenceType {
  DAILY_PRODUCTION_LINE
  DELIVERY_TICKET_LINE_ITEM
  PURCHASE_RECEIPT_LINE
}

/// Append-only ledger for stock inventory changes.
model InventoryTransaction {
  id              String                   @id @default(cuid())
  productId       String
  quantityChange  Decimal                  @db.Decimal(12, 4)
  transactionType InventoryTransactionType
  transactionDate DateTime
  referenceType   InventoryReferenceType?
  referenceId     String?
  notes           String?
  createdBy       String?
  createdAt       DateTime                 @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([transactionDate])
  @@index([productId, transactionDate])
  @@index([referenceType, referenceId])
}

/// Daily batch entry for stock production (yard output).
model DailyProductionEntry {
  id             String   @id @default(cuid())
  productionDate DateTime @db.Date
  batchLabel     String?
  enteredBy      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines DailyProductionLine[]

  @@index([productionDate])
}

/// One product/qty row on a daily production entry.
model DailyProductionLine {
  id               String  @id @default(cuid())
  productionEntryId String
  productId        String
  quantityProduced Decimal @db.Decimal(12, 4)

  productionEntry DailyProductionEntry @relation(fields: [productionEntryId], references: [id], onDelete: Cascade)
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productionEntryId])
  @@index([productId])
}

/// Batch entry for purchased casting inventory received from a supplier.
model PurchaseReceiptEntry {
  id           String   @id @default(cuid())
  receiptDate  DateTime @db.Date
  supplierId   String?
  batchLabel   String?
  enteredBy    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier CastingSupplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines    PurchaseReceiptLine[]

  @@index([receiptDate])
  @@index([supplierId])
}

/// One product/qty row on a purchase receipt entry.
model PurchaseReceiptLine {
  id                String  @id @default(cuid())
  purchaseReceiptId String
  productId         String
  quantityReceived  Decimal @db.Decimal(12, 4)

  purchaseReceipt PurchaseReceiptEntry @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([purchaseReceiptId])
  @@index([productId])
}

/// Daily confirmation that printed paper tickets match digital records.
model DeliveryDayReconciliation {
  id                 String   @id @default(cuid())
  reconciliationDate DateTime @unique @db.Date
  confirmedBy        String?
  confirmedAt        DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum InvoiceLineType {
  STOCK_PRODUCT
  CONFIGURABLE_STRUCTURE
  CUSTOM_STRUCTURE
  SERVICE
  MISC
}

/// Customer invoice — one per delivered delivery ticket.
model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  year            Int
  yearTwoDigit    Int
  sequenceNumber  Int
  deliveryTicketId String       @unique
  jobId           String?
  quoteId         String?
  customerId      String?
  jobNumber       String?
  customerName    String
  projectName     String
  status          InvoiceStatus @default(DRAFT)
  subtotal        Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  deliveryAmount  Decimal       @default(0) @db.Decimal(12, 2)
  taxableAmount   Decimal       @default(0) @db.Decimal(12, 2)
  taxRate         Decimal       @default(0) @db.Decimal(6, 4)
  salesTax        Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @default(0) @db.Decimal(12, 2)
  invoiceDate     DateTime?
  dueDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  deliveryTicket DeliveryTicket @relation(fields: [deliveryTicketId], references: [id], onDelete: Restrict)
  job            Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quote          Quote?         @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lineItems      InvoiceLineItem[]

  @@unique([year, sequenceNumber])
  @@index([jobId])
  @@index([quoteId])
  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
}

model InvoiceLineItem {
  id                       String          @id @default(cuid())
  invoiceId                String
  lineNumber               Int
  lineType                 InvoiceLineType
  quoteLineItemId          String?
  deliveryTicketLineItemId String?
  productId                String?
  itemCode                 String
  description              String?
  quantity                 Decimal         @default(1) @db.Decimal(12, 4)
  unit                     String          @default("EA")
  unitPrice                Decimal         @default(0) @db.Decimal(12, 2)
  taxable                  Boolean         @default(true)
  total                    Decimal         @default(0) @db.Decimal(12, 2)
  sortOrder                Int             @default(0)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  invoice                Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  quoteLineItem          QuoteLineItem?          @relation(fields: [quoteLineItemId], references: [id], onDelete: SetNull)
  deliveryTicketLineItem DeliveryTicketLineItem? @relation(fields: [deliveryTicketLineItemId], references: [id], onDelete: SetNull)
  product                Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([quoteLineItemId])
  @@index([deliveryTicketLineItemId])
  @@index([productId])
}

/// Per-year sequence counter for invoice numbers.
model InvoiceSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Product pricing list for quotes and walk-in delivery tickets.
model PriceList {
  id            String    @id @default(cuid())
  name          String    @unique
  effectiveDate DateTime?
  isDefault     Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items           PriceListItem[]
  quotes          Quote[]
  deliveryTickets DeliveryTicket[]
}

model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  unitPrice   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@index([productId])
}

/// Singleton application configuration (id is always "default").
model AppSettings {
  id        String   @id @default("default")
  // company
  companyName     String
  companyAddress  String
  companyPhone    String
  companyEmail    String
  appTitle        String
  appSubtitle     String
  quoteFooterText String?
  deliveryTicketCopy1Title   String?
  deliveryTicketCopy2Title   String?
  deliveryTicketCopy3Title   String?
  deliveryTicketFooterText   String?
  companyLogoPath   String?
  // paths
  jobsRoot            String
  quotePdfFallbackDir String
  stockSubmittalsRoot String
  jobSubfolders       Json
  // billing
  defaultTaxRate    Decimal @db.Decimal(6, 3)
  quoteValidityDays Int
  invoiceDueDays    Int
  defaultLeadTime   String?
  paymentTerms      Json
  // operations
  estimators         Json
  trucks             Json
  drivers            Json
  trailers           Json
  truckCapacityLabel String
  productCatalog     Json
  ringBuilderConfig  Json     @default("[]")
  rolePermissions    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  ESTIMATOR
  DISPATCHER
  PRODUCTION
  OFFICE
  READ_ONLY
}

enum AppPermission {
  CUSTOMERS_VIEW
  CUSTOMERS_MANAGE
  PRODUCTS_VIEW
  PRODUCTS_MANAGE
  STRUCTURES_VIEW
  STRUCTURES_MANAGE
  JOBS_VIEW
  JOBS_MANAGE
  QUOTES_VIEW
  QUOTES_MANAGE
  PRODUCTION_VIEW
  PRODUCTION_MANAGE
  INVOICES_VIEW
  INVOICES_MANAGE
  DELIVERY_VIEW
  DELIVERY_MANAGE
  INVENTORY_VIEW
  INVENTORY_MANAGE
  FILES_VIEW
  FILES_MANAGE
  SETTINGS_VIEW
  SETTINGS_MANAGE
  USERS_MANAGE
}

model User {
  id                 String          @id @default(cuid())
  username           String          @unique
  displayName        String
  initials           String
  email              String?
  role               UserRole        @default(OFFICE)
  grantedPermissions AppPermission[] @default([])
  deniedPermissions  AppPermission[] @default([])
  passwordHash       String?
  mustChangePassword Boolean         @default(false)
  isActive           Boolean         @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  sessions      Session[]
  auditLogs     AuditLog[]
  jobFavorites  JobFavorite[]
  quotesCreated Quote[]         @relation("QuoteCreatedBy")
}

model JobFavorite {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
